{
	"name": "helog-api",
	"version": "0.0.0",
	"private": true,
	"engines": {
		"node": ">=22"
	},
	"description": "This project is HeLog's API server.",
	"main": "index.js",
	"type": "module",
	"scripts": {
		"start": "NODE_ENV=production DEBUG=App:* node dist/index.js",
		"build": "rimraf dist && tsc && cp -r src/public dist/public",
		"dev": "NODE_ENV=development DEBUG=App:* tsx watch --env-file=.env src/index.ts",
		"seed": "DEBUG=App:* tsx --env-file=.env src/seed/index.ts",
		"test": "vitest",
		"coverage": "vitest --coverage"
	},
	"dependencies": {
		"argon2": "^0.44.0",
		"connect-mongo": "^5.1.0",
		"cors": "^2.8.5",
		"debug": "~2.6.9",
		"express": "^4.22.1",
		"express-async-handler": "^1.2.0",
		"express-session": "^1.18.2",
		"express-validator": "^7.3.1",
		"helmet": "^8.0.0",
		"mailgun.js": "^12.2.0",
		"mjml": "^4.18.0",
		"mongoose": "^8.12.1",
		"morgan": "~1.10.1",
		"passport": "^0.7.0",
		"passport-facebook": "^3.0.0",
		"passport-google-oauth20": "^2.0.0",
		"passport-local": "^1.0.0",
		"rate-limiter-flexible": "^9.0.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.6.1",
		"@commitlint/config-conventional": "^19.6.0",
		"@eslint/js": "^9.17.0",
		"@faker-js/faker": "^9.3.0",
		"@prettier/plugin-pug": "^3.4.2",
		"@tsconfig/node22": "^22.0.5",
		"@types/cors": "^2.8.18",
		"@types/debug": "^4.1.12",
		"@types/express": "^5.0.2",
		"@types/express-session": "^1.18.1",
		"@types/mjml": "^4.7.4",
		"@types/morgan": "^1.9.9",
		"@types/node": "^22.15.21",
		"@types/passport": "^1.0.17",
		"@types/passport-facebook": "^3.0.3",
		"@types/passport-google-oauth20": "^2.0.16",
		"@types/passport-local": "^1.0.38",
		"@types/supertest": "^6.0.3",
		"@vitest/coverage-v8": "^3.2.4",
		"eslint": "^9.17.0",
		"globals": "^15.13.0",
		"mongodb-memory-server": "^11.1.0",
		"prettier-plugin-css-order": "^2.1.2",
		"rimraf": "^6.1.3",
		"supertest": "^7.0.0",
		"tsx": "^4.19.4",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.32.1",
		"vitest": "^3.2.4"
	}
}
